# Supabase の「Project Settings → Database → Connection string」からコピーする
#
# DATABASE_URL: アプリの通常アクセス用。Transaction pooler（ポート 6543）を使う。
#   末尾に ?pgbouncer=true&connection_limit=1 を付けるとサーバーレスで安定する。
DATABASE_URL="postgresql://postgres.xxxxxxxxxxxx:[YOUR-PASSWORD]@aws-0-ap-northeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"

# DIRECT_URL: `prisma migrate` 実行時に使う直接接続（ポート 5432）。
DIRECT_URL="postgresql://postgres.xxxxxxxxxxxx:[YOUR-PASSWORD]@aws-0-ap-northeast-1.pooler.supabase.com:5432/postgres"

# ACCELERATE_URL（任意）: Prisma Accelerate を使う場合のみ設定する。
# console.prisma.io で「Import an existing database」から作成し、発行される
# prisma+postgres://accelerate.prisma-data.net/?api_key=... をそのまま貼る。
# 未設定の場合は DATABASE_URL / DIRECT_URL でこれまで通り直接 Supabase に接続する。
# ACCELERATE_URL="prisma+postgres://accelerate.prisma-data.net/?api_key=xxxxxxxxxxxx"
